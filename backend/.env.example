# Application
APP_NAME=MPCashews
APP_ENV=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=["http://localhost:3000","http://localhost:8000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mpcashews_db
DATABASE_ECHO=False

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Delivery Partner (Shiprocket)
SHIPROCKET_EMAIL=your-shiprocket-email
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external

# File Upload
UPLOAD_DIR=static/uploads
MAX_FILE_SIZE_MB=5

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# WhatsApp Business Cloud API (Meta)
# Get these from: https://developers.facebook.com/apps -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=your-whatsapp-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# WhatsApp template names (must match approved templates in Meta Business Manager)
WA_TEMPLATE_ORDER_CONFIRMED=order_confirmed
WA_TEMPLATE_ORDER_SHIPPED=order_shipped
WA_TEMPLATE_ORDER_CANCELLED=order_cancelled
WA_TEMPLATE_ORDER_DELIVERED=order_delivered
WA_TEMPLATE_ORDER_OUT_DELIVERY=order_out_for_delivery
WA_TEMPLATE_OTP=otp_verification
WA_TEMPLATE_LANGUAGE=en

# OTP
OTP_EXPIRE_MINUTES=10


